generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String?
  email    String  @unique
  password String

  tasks     Task[]
  schedules Schedule[]
}

model Task {
  id        Int     @id @default(autoincrement())
  title     String
  completed Boolean @default(false)

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Schedule {
  id      Int      @id @default(autoincrement())
  client  String
  service String
  date    DateTime

  userId Int
  user   User @relation(fields: [userId], references: [id])
}
